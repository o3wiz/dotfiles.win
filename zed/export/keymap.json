[
  {
    "context": "showing_completions",
    "bindings": {
      "ctrl-y": "editor::ConfirmCompletion"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-n": "editor::MoveDown",
      "ctrl-p": "editor::MoveUp",
      "ctrl-a": [
        "editor::MoveToBeginningOfLine",
        { "stop_at_soft_wraps": true, "stop_at_indent": true }
      ],
      "ctrl-e": ["editor::MoveToEndOfLine", { "stop_at_soft_wraps": true }],
      "alt-f": "editor::MoveToNextWordEnd",
      "alt-b": "editor::MoveToPreviousWordStart",
      "ctrl-alt-f": "editor::MoveToNextSubwordEnd",
      "ctrl-alt-b": "editor::MoveToPreviousSubwordStart",
      "alt-}": "editor::SelectLargerSyntaxNode",
      "alt-{": "editor::SelectSmallerSyntaxNode",
      "ctrl-L": "editor::SelectUp",
      "alt->": ["editor::SelectNext", { "replace_newest": false }],
      "alt-<": ["editor::SelectPrevious", { "replace_newest": false }],
      "alt-shift-;": "editor::SelectAllMatches",
      "alt-k": "editor::MoveLineUp",
      "alt-j": "editor::MoveLineDown",
      "alt-K": "editor::DuplicateLineUp",
      "alt-J": "editor::DuplicateLineDown",
      "alt-h": [
        "editor::DeleteToPreviousWordStart",
        { "ignore_newlines": false, "ignore_brackets": false }
      ],
      "alt-d": [
        "editor::DeleteToNextWordEnd",
        { "ignore_newlines": false, "ignore_brackets": false }
      ],
      "ctrl-alt-h": "editor::DeleteToPreviousSubwordStart",
      "ctrl-alt-d": "editor::DeleteToNextSubwordEnd",
      "alt-O": "editor::NewlineAbove",
      "alt-o": "editor::NewlineBelow",
      "alt-G": "editor::MoveToBeginning",
      "alt-g": "editor::MoveToEnd"
    }
  },
  {
    "context": "Editor && in_snippet && has_next_tabstop && !showing_completions",
    "bindings": {
      "ctrl-k": "editor::NextSnippetTabstop"
    }
  },
  {
    "context": "Editor && in_snippet && has_previous_tabstop && !showing_completions",
    "bindings": {
      "ctrl-j": "editor::PreviousSnippetTabstop"
    }
  },
  {
    "bindings": {
      "ctrl-p": "menu::SelectPrevious",
      "ctrl-n": "menu::SelectNext",
      "ctrl-y": "menu::Confirm",
      "alt-G": "menu::SelectFirst",
      "alt-g": "menu::SelectLast"
    }
  },
  {
    "context": "Editor && showing_signature_help",
    "bindings": {
      "ctrl-p": "editor::SignatureHelpPrevious",
      "ctrl-n": "editor::SignatureHelpNext"
    }
  },
  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "ctrl-p": "editor::ContextMenuPrevious",
      "ctrl-n": "editor::ContextMenuNext"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-r": null,
      "ctrl-p": null,
      "ctrl-n": null,
      "ctrl-<": "file_finder::Toggle",
      "ctrl-w h": "workspace::ActivatePaneLeft",
      "ctrl-w j": "workspace::ActivatePaneDown",
      "ctrl-w k": "workspace::ActivatePaneUp",
      "ctrl-w l": "workspace::ActivatePaneRight",
      "ctrl-w ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-w ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-w ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-w ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-w alt-h": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "left", "focus": true, "clone": false }
      ],
      "ctrl-w alt-j": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "down", "focus": true, "clone": false }
      ],
      "ctrl-w alt-k": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "up", "focus": true, "clone": false }
      ],
      "ctrl-w alt-l": [
        "workspace::MoveItemToPaneInDirection",
        { "direction": "right", "focus": true, "clone": false }
      ]
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "%": "project_panel::NewFile"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-p": ["terminal::SendKeystroke", "ctrl-p"],
      "ctrl-n": ["terminal::SendKeystroke", "ctrl-n"]
    }
  },
  {
    "context": "Pane",
    "unbind": {
      "ctrl-w": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ]
    },
    "bindings": {
      "ctrl-w ctrl-c": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ],
      "ctrl-w c": [
        "pane::CloseActiveItem",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "alt-n": "project_panel::NewDirectory"
    },
    "bindings": {
      "alt-n": "project_panel::NewFile"
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "[": "project_panel::CollapseSelectedEntry",
      "ctrl-[": "project_panel::CollapseSelectedEntry",
      "]": "project_panel::ExpandSelectedEntry",
      "ctrl-]": "project_panel::ExpandSelectedEntry"
    }
  }
]
